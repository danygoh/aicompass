{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --no-cache && npx prisma generate && npm run build",
    "startCommand": "npm start",
    "noCache": true
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
